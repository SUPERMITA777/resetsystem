{
  "name": "local-agent",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "bin": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:exe": "tsc && caxa --input . --output ../public/downloads/ResetAgent.exe -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/dist/index.js\"",
    "build:mac": "tsc && caxa --input . --output ../public/downloads/ResetAgent_Mac -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/dist/index.js\"",
    "build:linux": "tsc && caxa --input . --output ../public/downloads/ResetAgent_Linux -- \"{{caxa}}/node_modules/.bin/node\" \"{{caxa}}/dist/index.js\"",
    "build:all": "npm run build:exe",
    "start": "ts-node src/index.ts"
  },
  "pkg": {
    "assets": [
      "node_modules/axios/**/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.14.0",
    "dotenv": "^17.4.1",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/qrcode-terminal": "^0.12.2",
    "@vercel/ncc": "^0.38.4",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
