{
  "name": "local-agent",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "bin": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:exe": "tsc && pkg . --targets node18-win-x64 --output ../public/downloads/ResetAgent.exe",
    "build:mac": "tsc && pkg . --targets node18-macos-x64 --output ../public/downloads/ResetAgent_Mac",
    "build:linux": "tsc && pkg . --targets node18-linux-x64 --output ../public/downloads/ResetAgent_Linux",
    "build:all": "npm run build:exe && npm run build:mac && npm run build:linux",
    "start": "ts-node src/index.ts"
  },
  "pkg": {
    "assets": [
      "node_modules/axios/**/*"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "axios": "^1.14.0",
    "dotenv": "^17.4.1",
    "pino": "^8.21.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/qrcode-terminal": "^0.12.2",
    "@vercel/ncc": "^0.38.4",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
